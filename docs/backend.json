
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user information for SampattiPro access control.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "enum": ["Super Admin", "Branch Manager", "Auditor", "IT Admin"],
          "description": "System access level."
        },
        "branch": {
          "type": "string",
          "description": "Primary branch location assigned to the user."
        }
      },
      "required": ["uid", "email"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Enterprise asset record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serialNumber": { "type": "string" },
        "name": { "type": "string" },
        "model": { "type": "string" },
        "category": { "type": "string" },
        "purchaseDate": { "type": "string" },
        "installationDate": { "type": "string" },
        "purchaseValue": { "type": "number" },
        "currentBookValue": { "type": "number" },
        "location": { "type": "string" },
        "department": { "type": "string" },
        "status": { "type": "string" },
        "warrantyPeriodMonths": { "type": "number" },
        "warrantyExpiry": { "type": "string" },
        "vendorName": { "type": "string" },
        "depreciationRate": { "type": "number" },
        "assetPhotoUrl": { "type": "string" },
        "invoiceUrl": { "type": "string" }
      },
      "required": ["name", "serialNumber", "category", "location"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Asset inventory records."
    }
  }
}
